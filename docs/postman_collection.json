      "name": "Neighbourhoods",
      "item": [
        {
          "name": "Get All Neighbourhoods",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/neighbourhoods?name=brickell&city=miami&state=fl&country=usa&latitude=25.7&longitude=-80.1&amenities=spa,pool&isFeatured=true",
              "host": ["{{baseUrl}}"],
              "path": ["neighbourhoods"],
              "query": [
                { "key": "name", "value": "brickell", "description": "Filter by name" },
                { "key": "city", "value": "miami" },
                { "key": "state", "value": "fl" },
                { "key": "country", "value": "usa" },
                { "key": "latitude", "value": "25.7" },
                { "key": "longitude", "value": "-80.1" },
                { "key": "amenities", "value": "spa,pool" },
                { "key": "isFeatured", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Create Neighbourhood",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/neighbourhoods",
              "host": ["{{baseUrl}}"],
              "path": ["neighbourhoods"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Miami Beach\",\n  \"slug\": \"miami-beach\",\n  \"shortDescription\": \"Beautiful beach\",\n  \"fullDescription\": \"Very beautiful beach.\",\n  \"heroImage\": \"url\",\n  \"themeImages\": [{\"url\": \"img1\", \"index\": 1}],\n  \"amenities\": [\"swimming pool\", \"spa\"],\n  \"location\": {\n    \"city\": \"Miami\",\n    \"state\": \"FL\",\n    \"country\": \"USA\",\n    \"latitude\": 25.7906,\n    \"longitude\": -80.1300,\n    \"mapEmbedUrl\": \"url\"\n  },\n  \"isFeatured\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
