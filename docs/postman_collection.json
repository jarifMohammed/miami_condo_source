    {
      "name": "Contacts",
      "item": [
        {
          "name": "Get All Contacts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contacts?status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["contacts"],
              "query": [
                { "key": "status", "value": "pending" }
              ]
            }
          }
        },
        {
          "name": "Create Contact Request",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["contacts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phoneNumber\": \"555-0199\",\n  \"budget\": \"$1M - $2M\",\n  \"primaryGoal\": \"Investment\",\n  \"timeline\": \"3-6 months\",\n  \"message\": \"I am interested in pre-construction projects.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Mark Contact Completed",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/contacts/:id",
              "host": ["{{baseUrl}}"],
              "path": ["contacts", ":id"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}",
              "options": {
                "raw": {
                  "language": "json"
